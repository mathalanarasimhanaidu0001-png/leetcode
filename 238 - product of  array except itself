#include <vector>

class Solution {
public:
    std::vector<int> productExceptSelf(std::vector<int>& nums) {
        int n = nums.size();
        std::vector<int> ans(n, 1);
        
        // 1. Calculate Prefix products in one line inside the loop
        for (int i = 1; i < n; i++) 
            ans[i] = ans[i - 1] * nums[i - 1];
        
        // 2. Calculate Suffix products and multiply dynamically
        for (int i = n - 1, right = 1; i >= 0; i--) {
            ans[i] *= right;
            right *= nums[i];
        }
        
        return ans;
    }
};



====>   C++ SOLUTION OF 238 USING PREFIX X SUFFIX PATTERN 
 VISUAL - TWO PASSES : LEFT - PRODUCTS , RIGHT - PRODUCTS 



class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n=nums.size();
        vector<int>ans(n,1);
        
        int leftproduct=1; 
        for(int i=0;i<n;i++)
        {
            ans[i]=leftproduct;
            leftproduct*=nums[i];
        }
        int rightproduct=1;
        for(int i=n-1;i>=0;i--)
        {
            ans[i]*=rightproduct;
            rightproduct*=nums[i];
        }
        return ans;
        
    }
};
